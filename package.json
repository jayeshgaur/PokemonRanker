{
  "name": "pokemon-ranker",
  "private": true,
  "version": "0.0.0",
  "description": "Community-driven Pokémon ranking platform",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @pokemon-ranker/web dev",
    "build": "pnpm --filter @pokemon-ranker/web build",
    "start": "pnpm --filter @pokemon-ranker/web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=22"
  }
}
